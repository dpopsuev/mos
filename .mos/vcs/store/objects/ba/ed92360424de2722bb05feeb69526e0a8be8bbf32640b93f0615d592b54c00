contract "CON-2026-013" {
  title = "Harness Runner"
  status = "complete"
  goal = "`mos harness run .` discovers and executes all harness blocks from `.mos/rules/`, reports pass/fail, and Mos's own rules pass."

  coverage {

    unit {
      applies = true
      rationale = "Evidence model construction, report formatting, timeout logic, JUnit XML parsing."
    }

    integration {
      applies = true
      rationale = "Runner discovers rules from .cst/rules/, executes commands, produces evidence. Full pipeline."
    }

    contract {
      applies = false
      rationale = "No external API."
    }

    e2e {
      applies = true
      rationale = "mos harness run . against Mos's own rules. Both harness commands pass."
    }

    concurrency {
      applies = false
      rationale = "Sequential execution only."
    }

    security {
      applies = true
      rationale = "Harness commands are user-defined shell commands. See security assessment."
    }
  }

  feature "Harness Bridge" {

    scenario "Discover and execute harness blocks" {
      given {
        a .cst/ directory with two rules containing harness blocks
        rule "go-build-pass" with harness command "go build ./..."
        rule "tests-pass" with harness command "go test ./..."
      }
      when {
        cst harness run . is executed
      }
      then {
        both harness commands are executed
        each produces an Evidence record with: rule ID, command, exit code, duration
        exit code is 0 (all pass)
      }
    }

    scenario "Failing harness command" {
      given {
        a rule with harness command "false" (always exits 1)
      }
      when {
        cst harness run . is executed
      }
      then {
        the Evidence record shows exit code 1 and pass = false
        the overall exit code is 1
        the report clearly identifies which rule failed
      }
    }

    scenario "Timeout enforcement" {
      given {
        a rule with harness command "sleep 60" and timeout = "1s"
      }
      when {
        cst harness run . is executed
      }
      then {
        the command is killed after 1 second
        the Evidence record shows pass = false with a timeout indication
      }
    }

    scenario "JSON output" {
      given {
        harness execution produces evidence
      }
      when {
        cst harness run . --output json is executed
      }
      then {
        output is valid JSON
        each evidence entry contains: rule_id, command, exit_code, duration_ms, pass
      }
    }

    scenario "Mos dog-food" {
      given {
        Mos's .cst/rules/ contains go-build-pass and tests-pass
      }
      when {
        cst harness run . is executed in the mos repository root
      }
      then {
        go build ./... passes
        go test ./... passes
        overall exit code is 0
      }
    }
  }
}


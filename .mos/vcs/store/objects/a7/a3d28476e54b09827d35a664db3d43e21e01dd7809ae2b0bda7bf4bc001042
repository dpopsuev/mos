rule "flatten-nesting" {
  name = "Flatten Nesting Depth"
  type = "mechanical"
  scope = "project"
  enforcement = "warning"
  trigger = "pre-commit"
  vector = "structural"
  glob = "**/*.go"

  section "rationale" {
    text = "Deeply nested if/for/switch blocks hurt readability and signal missing abstractions. Prefer early returns, guard clauses, helper functions, and map-based lookup over nested conditionals. Maximum nesting depth inside a function body: 3 levels."
  }

  section "pattern" {
    text = "Extract repeated field-lookup-and-type-assert loops into typed map helpers (e.g. fieldMap, listFieldStrings) so call sites stay at 1-2 levels of indentation."
  }

  section "example_bad" {
    text = """
func (s *Scenario) Labels() []string {
  for _, f := range s.Fields {
    if f.Key == "labels" {
      if lv, ok := f.Value.(*ListVal); ok {
        var out []string
        for _, item := range lv.Items {
          if sv, ok := item.(*StringVal); ok {
            out = append(out, sv.Text)
          }
        }
        return out
      }
    }
  }
  return nil
}"""
  }

  section "example_good" {
    text = """
func (s *Scenario) Labels() []string {
  lv, ok := s.listField("labels")
  if !ok {
    return nil
  }
  return lv.Strings()
}"""
  }

  config {
    metric = "nesting_depth"
    ceiling = 3
    floor = 0

    language "go" {
      ceiling = 4
    }
  }

  harness {
    command = "go vet ./..."
    timeout = "60s"
  }
}


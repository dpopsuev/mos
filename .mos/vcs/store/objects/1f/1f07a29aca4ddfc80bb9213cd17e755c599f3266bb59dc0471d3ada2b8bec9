contract "CON-2026-059" {
  title = "Artifacts, Policies, Predicates"
  status = "complete"
  created_at = 2026-03-03T18:16:38Z
  updated_at = 2026-03-03T20:40:19Z
  goal = "Three-layer enforcement model inspired by RBAC separation: (1) Artifacts hold free-form fields — no schema-level restriction on values. (2) Policies are rules that declare enforcement behavior. (3) Predicates (when blocks) bind policies to artifacts based on field-value matching. This decouples data from enforcement: fields stay free-form, policies declare what they care about, predicates wire the two together. ROGYB is the first policy to implement on this pattern."
  justifies = "NEED-2026-001"
  kind = "feature"
  slug = "artifacts-policies-predicates"

  feature "Predicate matching" {

    scenario "Single field equality matches artifact" {
      given {
        a rule with when block containing kind = contract
      }
      when {
        evaluated against an artifact with kind = contract
      }
      then {
        the predicate matches and the policy applies
      }
    }

    scenario "Multi-field AND requires all fields to match" {
      given {
        a rule with when block containing kind = contract and status = active
      }
      when {
        evaluated against an artifact with kind = contract but status = draft
      }
      then {
        the predicate does not match because all fields must match
      }
    }

    scenario "Non-matching predicate skips artifact" {
      given {
        a rule with when block containing kind = specification
      }
      when {
        evaluated against a contract artifact
      }
      then {
        the predicate does not match and the policy is skipped
      }
    }

    scenario "Rule without when block is not a policy" {
      given {
        a rule with no when block
      }
      when {
        policies are loaded from rules
      }
      then {
        the rule is excluded from the policy list
      }
    }
  }

  feature "Policy evaluation during lint" {

    scenario "Matching policies reported as diagnostics" {
      given {
        a policy with enforcement = warning and a matching artifact
      }
      when {
        mos lint is executed
      }
      then {
        a warning diagnostic is emitted for the matching artifact
      }
    }

    scenario "Enforcement severity controls diagnostic level" {
      given {
        policies with enforcement levels error, warning, and info
      }
      when {
        evaluated against matching artifacts
      }
      then {
        diagnostics are emitted at the corresponding severity
      }
    }

    scenario "No false positives for non-matching artifacts" {
      given {
        a policy with predicates that match only specifications
      }
      when {
        mos lint is executed across all artifacts
      }
      then {
        no diagnostic is emitted for contract artifacts
      }
    }
  }

  feature "ROGYB first policy" {

    scenario "Feature contracts require harness coverage" {
      given {
        the rogyb-harness-required rule with when kind = contract
      }
      when {
        a feature contract without harness block is linted
      }
      then {
        a policy-match diagnostic is emitted at the rule enforcement level
      }
    }

    scenario "Non-feature contracts are unaffected" {
      given {
        the rogyb-harness-required rule with when kind = contract and contract_kind = feature
      }
      when {
        a housekeeping contract is linted
      }
      then {
        no policy-match diagnostic is emitted
      }
    }
  }
}


blob
contract "CON-2026-036" {
  title = "Compartmentalization & Information Security"
  status = "deferred"
  created_at = 2026-03-03T15:02:42Z
  updated_at = 2026-03-03T19:10:45Z
  goal = "Information compartmentalization primitive: clearance levels, codeword access, opaque references, audit logging, declassification, dead mans key, sealed governance chains. Born from military downstream consumers (USSN, SRJSN) and validated by the Phobos War and Quiet War catastrophic data loss events."
  labels = ["dogfood", "simulation", "dunix", "security"]
  parent = "CON-2026-029"

  feature "Compartment definition" {

    scenario "Define a compartment in config.mos" {
      status = "pending"
      given {
        a mos workspace with config.mos
      }
      when {
        a compartment block is added with clearance secret, codeword TRIDENT, access list [alice, bob], visibility opaque, audit true
      }
      then {
        the compartment TRIDENT is registered
        only operators alice and bob have access
        audit logging is enabled for the compartment
      }
    }

    scenario "Multiple compartments with different clearance levels" {
      status = "pending"
      given {
        config.mos defines compartment FLEET-OPS (secret) and compartment SIGINT (top-secret)
      }
      when {
        the registry is loaded
      }
      then {
        two compartments exist with distinct clearance levels
        SIGINT has higher clearance than FLEET-OPS
        access lists are independent
      }
    }

    scenario "Artifact tagged with compartment" {
      status = "pending"
      given {
        compartment FLEET-OPS is defined with access [alice, bob]
      }
      when {
        alice creates a contract with compartment = FLEET-OPS
      }
      then {
        the contract file contains compartment = FLEET-OPS
        alice can read the full contract
        bob can read the full contract
      }
    }
  }

  feature "Opaque references" {

    scenario "Unauthorized operator sees redacted artifact" {
      status = "pending"
      given {
        a contract CON-001 with compartment FLEET-OPS
        operator charlie is not in the FLEET-OPS access list
      }
      when {
        charlie runs mos contract show CON-001
      }
      then {
        charlie sees ID and kind only
        title is redacted
        goal is redacted
        features and scenarios are not shown
      }
    }

    scenario "Unauthorized operator sees redacted list" {
      status = "pending"
      given {
        3 contracts exist: CON-001 (FLEET-OPS), CON-002 (unclassified), CON-003 (FLEET-OPS)
        operator charlie has no compartment access
      }
      when {
        charlie runs mos contract list
      }
      then {
        CON-002 shows full title and status
        CON-001 and CON-003 show ID and kind but redacted titles
      }
    }

    scenario "Cross-reference to opaque artifact resolves gracefully" {
      status = "pending"
      given {
        a need NEED-001 with compartment FLEET-OPS
        a specification SPEC-001 (unclassified) that justifies NEED-001
        operator charlie has no compartment access
      }
      when {
        charlie runs the linter
      }
      then {
        the linter resolves NEED-001 as exists: true, clearance: denied
        no lifecycle-chain error is raised
        the governance graph edge from SPEC-001 to NEED-001 is tracked
        content-level validation (orphan, criterion, scope) is skipped for NEED-001
      }
    }

    scenario "Linter skips orphan detection for opaque artifacts" {
      status = "pending"
      given {
        a need NEED-001 with compartment FLEET-OPS and no downstream specifications
      }
      when {
        the linter runs for an operator without FLEET-OPS access
      }
      then {
        no lifecycle-orphan diagnostic is raised for NEED-001
        NEED-001 appears as an opaque node in the governance graph
      }
    }

    scenario "Linter skips criterion coverage for opaque specs" {
      status = "pending"
      given {
        a need NEED-001 (unclassified) with acceptance criteria
        a specification SPEC-001 with compartment FLEET-OPS that addresses criterion C1
      }
      when {
        the linter runs for an operator without FLEET-OPS access
      }
      then {
        criterion C1 is not flagged as uncovered
        the linter acknowledges an opaque spec addresses it
      }
    }
  }

  feature "Compartment seal enforcement" {

    scenario "Compartmented artifact requires cleared operator for seal" {
      status = "pending"
      given {
        a contract CON-001 with compartment FLEET-OPS (access [alice, bob])
      }
      when {
        charlie (not in access list) attempts to seal CON-001
      }
      then {
        the seal is rejected with clearance denied
        authority level alone is insufficient
      }
    }

    scenario "Cleared operator can seal compartmented artifact" {
      status = "pending"
      given {
        a contract CON-001 with compartment FLEET-OPS (access [alice])
      }
      when {
        alice seals CON-001 with intent ship
      }
      then {
        the seal is applied
        the seal includes alice's operator identity
      }
    }
  }

  feature "Audit logging" {

    scenario "Read access to compartmented artifact is logged" {
      status = "pending"
      given {
        compartment FLEET-OPS with audit = true
        a contract CON-001 in FLEET-OPS
      }
      when {
        alice runs mos contract show CON-001
      }
      then {
        an entry is appended to .mos/audit/FLEET-OPS.log
        the entry contains operator alice, timestamp, action read, artifact CON-001
      }
    }

    scenario "Write access to compartmented artifact is logged" {
      status = "pending"
      given {
        compartment FLEET-OPS with audit = true
      }
      when {
        bob creates a new contract with compartment FLEET-OPS
      }
      then {
        an entry is appended to .mos/audit/FLEET-OPS.log
        the entry contains operator bob, timestamp, action create, artifact ID
      }
    }

    scenario "Denied access attempt is logged" {
      status = "pending"
      given {
        compartment FLEET-OPS with audit = true
        operator charlie not in access list
      }
      when {
        charlie attempts to read a FLEET-OPS artifact
      }
      then {
        an entry is appended to .mos/audit/FLEET-OPS.log
        the entry contains operator charlie, timestamp, action denied, artifact ID
      }
    }
  }

  feature "Declassification" {

    scenario "Declassify artifact removes compartment" {
      status = "pending"
      given {
        a contract CON-001 with compartment FLEET-OPS
        operator alice has authority level >= secret
      }
      when {
        alice runs mos artifact declassify CON-001
      }
      then {
        the compartment field is removed from CON-001
        CON-001 is now fully visible to all operators
        a declassification event is appended to the ledger
        the sealed audit chain is preserved
      }
    }

    scenario "Insufficient authority cannot declassify" {
      status = "pending"
      given {
        a contract CON-001 with compartment FLEET-OPS (clearance secret)
        operator dave has authority level < secret
      }
      when {
        dave runs mos artifact declassify CON-001
      }
      then {
        the declassification is rejected
        the compartment remains
      }
    }

    scenario "Declassification preserves governance graph" {
      status = "pending"
      given {
        a need NEED-001 was compartmented and justified by SPEC-001
        NEED-001 is declassified
      }
      when {
        the linter runs
      }
      then {
        the justifies link from SPEC-001 to NEED-001 is now fully validated
        content-level validation resumes for NEED-001
        previously opaque references become normal references
      }
    }
  }

  feature "Dead man's key" {

    scenario "Export encrypted metadata for compartment" {
      status = "pending"
      given {
        compartment FLEET-OPS with 5 artifacts and cross-references
      }
      when {
        mos compartment dead-mans-key FLEET-OPS is run
      }
      then {
        an encrypted metadata file is produced
        the file contains artifact IDs and governance graph edges
        the file does not contain artifact content (titles, goals, scenarios)
        the file can be decrypted by Luna arbiter key
      }
    }

    scenario "Graph reconstruction from dead man's key" {
      status = "pending"
      given {
        a compartmented repo is destroyed (Phobos scenario)
        the dead man's key metadata exists at Luna
      }
      when {
        the metadata is decrypted and applied
      }
      then {
        artifact IDs are known (CON-001 through CON-005)
        governance graph edges are reconstructed (justifies, implements links)
        artifact content remains unknown (titles, goals are lost)
        the governance graph shows the correct topology with opaque placeholder content
      }
    }
  }

  feature "Sealed governance chains" {

    scenario "Seal includes merkle root of upstream references" {
      status = "pending"
      given {
        a contract CON-001 that implements SPEC-001 which justifies NEED-001
      }
      when {
        CON-001 is sealed
      }
      then {
        the seal block contains a merkle_root field
        the merkle root covers the subgraph: CON-001 -> SPEC-001 -> NEED-001
      }
    }

    scenario "Corrupted graph detected via seal verification" {
      status = "pending"
      given {
        a sealed contract CON-001 with merkle root covering SPEC-001 -> NEED-001
        the implements link on CON-001 is corrupted to point to SPEC-999
      }
      when {
        seal integrity is verified
      }
      then {
        the verification fails
        the mismatch between stored merkle root and current graph is reported
        the pre-corruption state can be inferred from the seal
      }
    }

    scenario "Graph reconstruction from seal chain after Quiet War" {
      status = "pending"
      given {
        40% of cross-reference links are corrupted
        all artifacts have sealed governance chains
      }
      when {
        the reconstruction algorithm walks seal chains backwards
      }
      then {
        the pre-corruption governance graph is reconstructed
        corrupted links are identified and flagged
        reconstruction coverage >= 95% of the original graph
      }
    }
  }
  batch = "BAT-2026-002"
  slug = "compartmentalization"
}


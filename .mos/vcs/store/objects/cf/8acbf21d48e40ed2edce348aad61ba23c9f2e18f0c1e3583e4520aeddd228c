contract "CON-2026-030" {
  title = "Ordered enum fields and harness-verified state transitions"
  status = "complete"
  created_at = 2026-03-03T12:00:00Z
  updated_at = 2026-03-03T12:00:00Z
  goal = "Extend FieldDef with ordered = true to declare that an enum defines a state machine with forward-only progression. Add a verified_by field that links a field value transition to a harness execution requirement. The built-in scenario schema ships with status = enum [pending, implemented, verified], ordered = true, and verified_by = harness on the implemented->verified transition. mos contract verify CON-ID runs the linked harness for implemented scenarios and auto-transitions passing ones to verified with a verified_at timestamp. These are primitives: any artifact_type can define ordered enums and harness-gated transitions. The dual-gate behavior is a sane default, not a hardcoded feature."
  kind = "feature"
  depends_on = ["CON-2026-029", "CON-2026-028"]

  coverage {

    unit {
      applies = true
      rationale = "Ordered enum validation, forward-only enforcement, harness-gated transition logic."
    }

    integration {
      applies = true
      rationale = "mos contract verify round-trip: harness execution, auto-transition, timestamp recording."
    }

    contract {
      applies = false
    }

    e2e {
      applies = false
    }

    concurrency {
      applies = false
    }

    security {
      applies = false
    }
  }

  feature "Ordered Enum and Harness-Gated Transitions" {

    scenario "FieldDef supports ordered flag" {
      status = "done"
      given {
        a field definition with enum and ordered = true
      }
      when {
        the registry is loaded
      }
      then {
        the FieldDef has Ordered = true
        the enum values define a state progression
      }
    }

    scenario "Forward-only progression is enforced" {
      status = "done"
      given {
        an ordered enum field with states pending, implemented, verified
        a scenario currently in implemented state
      }
      when {
        an attempt is made to set status back to pending
      }
      then {
        the operation is rejected with a backward-transition error
      }
    }

    scenario "FieldDef supports verified_by for gated transitions" {
      status = "done"
      given {
        a field definition with a transition block
        the transition from implemented to verified has verified_by = harness
      }
      when {
        the registry is loaded
      }
      then {
        the FieldDef transition rules include a harness gate for that transition
      }
    }

    scenario "mos contract verify runs harness and transitions verified scenarios" {
      status = "done"
      given {
        a contract with 2 scenarios in implemented state
        a linked rule with a passing harness command
      }
      when {
        mos contract verify CON-ID is run
      }
      then {
        the harness executes
        passing scenarios transition to verified
        verified_at timestamps are recorded on each
      }
    }

    scenario "Failed harness keeps scenario in implemented state" {
      status = "done"
      given {
        a contract with an implemented scenario
        a linked harness that exits with code 1
      }
      when {
        mos contract verify CON-ID is run
      }
      then {
        the scenario remains implemented
        verified_at is not set
        evidence of the failure is recorded
      }
    }

    scenario "Default scenario schema ships with ordered enum and harness gate" {
      status = "done"
      given {
        a fresh mos init workspace
      }
      when {
        the built-in contract type scenario fields are inspected
      }
      then {
        scenario status has enum = pending, implemented, verified
        ordered = true
        the implemented to verified transition requires harness verification
      }
    }
  }
}


contract "CON-2026-020" {
  title = "Topology Operations"
  status = "complete"
  goal = "The Mos CLI provides safe, automated topology operations -- hierarchy promotion/demotion, repository splitting/merging, and federation union/secession -- that today are avoided because they are \"absolute hell with git\" and carry unacceptable risk of data loss, governance state corruption, and broken history."

  coverage {

    unit {
      applies = true
      rationale = "Checkpoint create/restore, pre-flight delta computation, vocabulary merge, rule deduplication, contract renumbering, upstream rewire, include path rewriting."
    }

    integration {
      applies = true
      rationale = "Full promote/demote/split/merge operations across multi-repo test workspaces. Git operations + .mos/ rewiring as a unit."
    }

    contract {
      applies = false
      rationale = "No external API. CLI-only operations."
    }

    e2e {
      applies = true
      rationale = "3-repo federation scenario: standalone repo promotes into federation, repo within federation demotes to standalone, repo splits into two, two repos merge. Full cycle."
    }

    concurrency {
      applies = true
      rationale = "Two agents running topology operations on overlapping repo sets simultaneously. Checkpoint/rollback must not corrupt. File locking (per CON-2026-015 race condition findings)."
    }

    security {
      applies = true
      rationale = "Git operations that touch remote URLs. Credential handling for git clone/git push during topology operations."
    }
  }

  feature "Topology Operations" {

    scenario "Pre-flight reports delta without mutating" {
      status = "done"
      given {
        a standalone repo "libutil" with 3 local rules and 5 vocabulary terms
        a federation root "org-root" with 10 inherited rules and 20 vocabulary terms
      }
      when {
        "mos topo promote libutil --parent org-root" is run without --confirm
      }
      then {
        a pre-flight report is printed showing:
        10 rules will be inherited
        2 local rules shadow inherited rules (names listed)
        15 new vocabulary terms will be added
        0 vocabulary conflicts
        no files are modified
        no git operations are performed
      }
    }

    scenario "Checkpoint enables rollback after failed operation" {
      status = "done"
      given {
        a repo "service-a" with upstream "org-root"
        a valid governance state (mos lint passes)
      }
      when {
        "mos topo demote service-a --standalone --confirm" runs
        the operation fails mid-way (simulated: include path resolution error)
      }
      then {
        "mos topo rollback" restores the checkpoint
        the upstream block is restored
        all include paths are restored
        "mos lint ." passes with zero errors
        the checkpoint git tag exists for audit
      }
    }

    scenario "Promote standalone repo into federation" {
      status = "done"
      given {
        a standalone repo "new-service" with local rules and vocabulary
        a federation root "org-root" with upstream rules and vocabulary
      }
      when {
        "mos topo promote new-service --parent org-root --confirm" is run
      }
      then {
        new-service's config.mos contains an upstream block pointing at org-root
        org-root's vocabulary terms are inherited by new-service
        org-root's rules cascade into new-service
        local rules that shadow inherited rules produce lint warnings
        "mos lint ." passes on both repos
      }
    }

    scenario "Promote repo from one parent to another within same org" {
      status = "done"
      given {
        repo "libutil" with upstream "team-platform"
        repo "team-infra" exists as a sibling of "team-platform" under "org-root"
      }
      when {
        "mos topo promote libutil --parent team-infra --confirm" is run
      }
      then {
        libutil's upstream changes from team-platform to team-infra
        vocabulary terms unique to team-platform are copied to libutil's local vocabulary
        vocabulary terms from team-infra are now inherited
        rules from team-platform stop cascading; rules from team-infra start cascading
        "mos lint ." passes on libutil, team-platform, and team-infra
      }
    }

    scenario "Demote repo to standalone preserving inherited state" {
      status = "done"
      given {
        repo "service-x" with upstream "org-root"
        service-x uses 5 inherited vocabulary terms and 3 inherited rules
      }
      when {
        "mos topo demote service-x --standalone --confirm" is run
        the operator selects "copy all" for inherited artifacts
      }
      then {
        service-x has no upstream block
        all 5 vocabulary terms are copied to service-x's local vocabulary
        all 3 inherited rules are copied to service-x's local rules directory
        "mos lint ." passes
        service-x is fully self-contained
      }
    }

    scenario "Split overloaded repo into two" {
      status = "done"
      given {
        repo "monolith" with:
        pkg/api/ (API domain, 2 contracts referencing these files)
        pkg/worker/ (worker domain, 1 contract referencing these files)
        3 project-wide rules
        1 api-scoped rule
        10 vocabulary terms
      }
      when {
        "mos topo split monolith --into api:pkg/api worker:pkg/worker --confirm" is run
      }
      then {
        two new repos exist: "api" and "worker"
        git history for pkg/api/ files is preserved in the "api" repo
        git history for pkg/worker/ files is preserved in the "worker" repo
        the 2 API contracts are in the "api" repo
        the 1 worker contract is in the "worker" repo
        all 3 project-wide rules exist in both repos
        the api-scoped rule exists only in the "api" repo
        all 10 vocabulary terms exist in both repos
        "mos lint ." passes on both repos
      }
    }

    scenario "Merge two tightly-coupled repos" {
      status = "done"
      given {
        repo "client" with contracts CON-2026-001, CON-2026-002 and 3 rules
        repo "server" with contracts CON-2026-001, CON-2026-003 and 2 rules
        1 rule is identical in both repos
        vocabulary term "endpoint" has different definitions in each repo
      }
      when {
        "mos topo merge client server --into fullstack --confirm" is run
      }
      then {
        one repo "fullstack" exists
        git history from both repos is preserved
        contracts are renumbered: client's CON-2026-001 and CON-2026-002 remain; server's CON-2026-001 becomes CON-2026-003 (or next available)
        the identical rule exists once (deduplicated)
        the differing "endpoint" definitions are flagged; operator resolves manually
        "mos lint ." passes after vocabulary conflict is resolved
      }
    }

    scenario "Union: batch promote multiple repos into federation" {
      status = "done"
      given {
        3 standalone repos: "svc-a", "svc-b", "svc-c"
        a federation root "org-root"
      }
      when {
        "mos topo union svc-a svc-b svc-c --federation org-root --communion partial --confirm" is run
      }
      then {
        all 3 repos have upstream blocks pointing at org-root
        org-root's product manifest lists all 3 repos
        Koinonia metadata is set to "partial" for each
        "mos lint ." passes on all 4 repos
      }
    }

    scenario "Secede: batch demote repos from federation" {
      status = "done"
      given {
        repos "svc-a" and "svc-b" with upstream "org-root"
        org-root's product manifest lists both
      }
      when {
        "mos topo secede svc-a svc-b --from org-root --confirm" is run
      }
      then {
        svc-a and svc-b have no upstream blocks
        inherited artifacts are copied to local per operator selection
        org-root's product manifest no longer lists svc-a or svc-b
        Koinonia metadata is set to "none"
        "mos lint ." passes on all repos
      }
    }

    scenario "History is never rewritten" {
      status = "done"
      given {
        repo "target" with 100 commits, 5 signed commits, 3 merge commits
      }
      when {
        any topology operation is performed on "target"
      }
      then {
        all 100 original commit hashes are unchanged
        all 5 signatures remain valid
        all 3 merge commits retain their parents
        no force-push is required
        "git fsck" passes
      }
    }
  }

  scope {
    depends_on = ["CON-2026-001", "CON-2026-015"]
  }
}


contract "CON-2026-111" {
  title = "mos status: project context in one shot"
  status = "complete"
  justifies = "SPEC-2026-028"
  sprint = "SPR-2026-004"
  created_at = 2026-03-03T21:32:33Z
  updated_at = 2026-03-04T09:29:49Z
  name = "mos status: project context in one shot"
  slug = "mos-status"
  description = "A single command that orients any participant — human or agent — at session start. Shows active sprint, open contracts, recent lint summary, MOTD, and drift snapshot. Eliminates the 4-5 command cold-start tax on every conversation. Critical for agentic workflow: agents spend tokens and time re-discovering project state every session."
  batch = "BAT-2026-006"
  goal = "A single command that orients any participant at session start. Eliminates the cold-start tax on every conversation."

  feature "One-shot project orientation" {

    scenario "Status shows active sprint" {
      given {
        an active sprint SPR-2026-004 exists
      }
      when {
        mos status is run
      }
      then {
        output includes the sprint ID, title, and goal
      }
    }

    scenario "Status shows open contracts" {
      given {
        draft contracts exist in .mos/contracts/active/
      }
      when {
        mos status is run
      }
      then {
        output lists open contracts with ID, title, and status
      }
    }

    scenario "Status shows lint summary" {
      given {
        a .mos/ project with artifacts
      }
      when {
        mos status is run
      }
      then {
        output includes lint error, warning, and info counts
      }
    }

    scenario "Status shows harness summary" {
      given {
        harness rules are configured
      }
      when {
        mos status is run
      }
      then {
        output includes harness pass/fail counts
      }
    }
  }

  coverage {

    unit {
      applies = true
    }

    integration {
      applies = true
    }
  }
}


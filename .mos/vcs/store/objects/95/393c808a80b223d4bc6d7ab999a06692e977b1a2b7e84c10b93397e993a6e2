contract "CON-2026-039" {
  title = "Lifecycle Orphan Detection Primitive"
  status = "complete"
  goal = "Generic expects_downstream block on CAD lifecycle. Linter rule lifecycle-orphan flags any artifact past a declared state threshold that has no downstream artifact referencing it via the declared link field. Sane defaults for need, specification, and architecture."

  feature "Orphan detection primitive" {

    scenario "CAD lifecycle schema supports expects_downstream" {
      status = "done"
      given {
        a freshly initialized mos workspace
      }
      when {
        the registry is loaded from config.mos
      }
      then {
        the need artifact_type lifecycle includes expects_downstream with via, after, and severity
        the specification artifact_type lifecycle includes expects_downstream
        the architecture artifact_type lifecycle includes expects_downstream
      }
    }

    scenario "Orphan need is flagged" {
      status = "done"
      given {
        a need NEED-001 at status validated
        no specification with justifies NEED-001
      }
      when {
        the linter runs
      }
      then {
        a lifecycle-orphan warning is raised for NEED-001
        the message indicates no downstream artifact references it via justifies
      }
    }

    scenario "Non-orphan need is clean" {
      status = "done"
      given {
        a need NEED-001 at status validated
        a specification SPEC-001 with justifies NEED-001
      }
      when {
        the linter runs
      }
      then {
        no lifecycle-orphan diagnostic is raised for NEED-001
      }
    }

    scenario "Orphan specification is flagged" {
      status = "done"
      given {
        a specification SPEC-001 at status active
        no architecture or contract with implements SPEC-001
      }
      when {
        the linter runs
      }
      then {
        a lifecycle-orphan warning is raised for SPEC-001
      }
    }

    scenario "Artifact below threshold state is not flagged" {
      status = "done"
      given {
        a need NEED-001 at status identified
        no specification referencing it
      }
      when {
        the linter runs
      }
      then {
        no lifecycle-orphan diagnostic is raised because identified is before the after threshold
      }
    }

    scenario "CAD without expects_downstream produces no diagnostics" {
      status = "done"
      given {
        a custom artifact type with no expects_downstream in its lifecycle
      }
      when {
        instances of that type exist with no downstream references
      }
      then {
        no lifecycle-orphan diagnostic is raised
      }
    }
  }
}


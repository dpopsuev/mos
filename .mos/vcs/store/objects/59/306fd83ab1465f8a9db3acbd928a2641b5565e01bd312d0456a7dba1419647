contract "CON-2026-035" {
  title = "Smoke & Scale Tests"
  status = "draft"
  created_at = 2026-03-03T14:47:43Z
  updated_at = 2026-03-03T19:10:45Z
  goal = "Validate the simulation engine at two scales: smoke (Era I only, compressed) and full (all 5 eras, 54,750 ticks)."
  labels = ["dogfood", "simulation", "dunix"]
  parent = "CON-2026-029"

  feature "Smoke test (Era I)" {

    scenario "Reduced-scale Genesis" {
      status = "pending"
      given {
        a simulation configured for Era I only (1825 ticks)
        time compression factor 10
      }
      when {
        the simulation runs to completion
      }
      then {
        Terra, Mars, and Luna sites exist
        at least 4 repos are created
        no panics or deadlocks
        total wall-clock time < 30 seconds
      }
    }

    scenario "Smoke linter performance" {
      status = "pending"
      given {
        Era I smoke simulation has completed
      }
      when {
        lint_time_ms metrics are inspected
      }
      then {
        maximum lint time < 1000ms
        no bottleneck flags raised
      }
    }

    scenario "Smoke determinism" {
      status = "pending"
      given {
        two smoke runs with seed 42
      }
      when {
        final metrics are compared
      }
      then {
        artifact counts are identical
        metric snapshots are identical
        bottleneck flags are identical
      }
    }
  }

  feature "Full simulation test (all eras)" {

    scenario "Full 150-year run completes" {
      status = "pending"
      given {
        a simulation configured for all 5 eras (54750 ticks)
      }
      when {
        the simulation runs to completion
      }
      then {
        all milestone events fired at their scheduled ticks
        10 sites exist at the end
        total wall-clock time < 10 minutes
      }
    }

    scenario "Bottleneck report is non-empty" {
      status = "pending"
      given {
        a completed full simulation
      }
      when {
        the bottleneck report is generated
      }
      then {
        at least 1 performance bottleneck was detected
        at least 1 governance bottleneck was detected
        the Enceladus Index is computed
      }
    }

    scenario "Governance model scorecard" {
      status = "pending"
      given {
        a completed full simulation
      }
      when {
        the scorecard is generated
      }
      then {
        all 6 governance models are scored
        each site has a per-era breakdown
        the report identifies the model with the best orphan rate
      }
    }

    scenario "Full simulation determinism" {
      status = "pending"
      given {
        two full runs with seed 7
      }
      when {
        bottleneck reports are compared
      }
      then {
        identical bottleneck flags
        identical governance scorecards
        identical Enceladus Index
      }
    }
  }
  batch = "BAT-2026-002"
  slug = "smoke-scale-tests"
}


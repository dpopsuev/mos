contract "CON-2026-038" {
  title = "Spec-to-Criterion Linkage"
  status = "complete"
  goal = "Specifications declare which acceptance criteria they fulfill via an addresses list field. Linter validates criterion-exists (addresses entries must exist on the linked need) and criterion-coverage (every criterion on a validated need must be addressed by at least one spec)."

  feature "Spec addresses criteria" {

    scenario "Specification CAD includes addresses field" {
      status = "done"
      given {
        a freshly initialized mos workspace
      }
      when {
        the registry is loaded from config.mos
      }
      then {
        the specification artifact_type definition includes an addresses list field
      }
    }

    scenario "Spec with valid addresses passes linter" {
      status = "done"
      given {
        a need NEED-001 with acceptance criteria sub-10-min and no-regression
        a specification SPEC-001 that justifies NEED-001 with addresses sub-10-min
      }
      when {
        the linter runs
      }
      then {
        no criterion-exists error is raised for SPEC-001
      }
    }

    scenario "Spec with dangling address errors" {
      status = "done"
      given {
        a need NEED-001 with acceptance criterion sub-10-min
        a specification SPEC-001 that justifies NEED-001 with addresses nonexistent-criterion
      }
      when {
        the linter runs
      }
      then {
        a criterion-exists error is raised for SPEC-001
        the message names the dangling criterion
      }
    }

    scenario "Uncovered criterion produces warning" {
      status = "done"
      given {
        a need NEED-001 at status validated with criteria sub-10-min and no-regression
        a specification SPEC-001 that addresses only sub-10-min
      }
      when {
        the linter runs
      }
      then {
        a criterion-coverage warning is raised for NEED-001
        the message names no-regression as uncovered
      }
    }

    scenario "Fully covered need produces no warnings" {
      status = "done"
      given {
        a need NEED-001 at status validated with criteria sub-10-min and no-regression
        specifications that collectively address both criteria
      }
      when {
        the linter runs
      }
      then {
        no criterion-coverage diagnostic is raised for NEED-001
      }
    }

    scenario "Chain output shows criterion coverage" {
      status = "done"
      given {
        a need with criteria linked to specs via addresses
      }
      when {
        the user runs mos chain NEED-001
      }
      then {
        the output includes per-criterion coverage status
      }
    }
  }
}


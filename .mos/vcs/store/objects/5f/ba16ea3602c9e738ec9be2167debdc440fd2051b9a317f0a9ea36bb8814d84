specification "SPEC-2026-031" {
  title = "Case Study: Anthropic — Effective Test Scaffolds for Long-Running Agents"
  status = "active"
  enforcement = "disabled"

  section "Source" {
    url = "https://www.anthropic.com/engineering/effective-harnesses-for-long-running-agents"
    author = "Justin Young, Anthropic"
    date = "2025-11-26"
  }

  section "Context" {
    text = "Anthropic addressed the challenge of agents working across many context windows. Each new session begins with no memory of prior work. Without structured handoff, agents either one-shot (and fail mid-implementation) or declare victory prematurely."
  }

  section "Key Findings" {
    text = "1. Two-agent pattern: An initializer agent sets up the environment (init.sh, progress file, feature list, git repo). Every subsequent coding agent makes incremental progress and leaves structured updates. 2. Feature list as structured JSON: A comprehensive list of features with pass/fail status. JSON is preferred over Markdown because models are less likely to inappropriately modify it. Strongly-worded instructions prevent agents from editing or removing features. 3. Progress file + git history: The claude-progress.txt file alongside git commit logs gives each new session a fast ramp-up. Agents read these first, then choose the next feature to work on. 4. Incremental progress: Agents work on one feature at a time. This was critical to prevent one-shotting. Each session ends with a git commit and progress update — a 'clean state' suitable for merging. 5. Self-verification: Agents must test features end-to-end (e.g. via Puppeteer MCP for web apps) before marking them done. Without explicit prompting, agents tend to mark features complete after cursory code review."
  }

  section "Relevance to Mos" {
    text = "Directly validates Mos's contract-and-scenario model. Anthropic's feature list with pass/fail status maps to Mos contracts with scenario done/pending tracking. Their progress file maps to Mos's history/ledger. Their incremental-progress-with-clean-handoff philosophy matches Mos's sprint model — planned, executed, verified via CLI. Key gap they identified: agents need a structured 'getting started' protocol. Mos's 'mos status' (CON-2026-111) addresses exactly this."
  }
  slug = "case-study-anthropic-harness"

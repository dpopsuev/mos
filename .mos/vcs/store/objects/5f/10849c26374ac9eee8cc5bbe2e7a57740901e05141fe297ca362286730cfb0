contract "CON-2026-137" {
  title = "ObjectStore migration between backends"
  status = "complete"
  created_at = 2026-03-04T13:10:05Z
  updated_at = 2026-03-04T13:10:05Z
  goal = "Implement mos vcs migrate --to <backend> that copies all objects and refs from the current backend to the target backend, verifies integrity, and updates config. Migration must be lossless and reversible."
  justifies = "SPEC-2026-001"
  batch = "BAT-2026-004"
  slug = "objectstore-migrate"
  depends_on = "CON-2026-136"

  feature "Store migration" {

    scenario "migrate fs to git" {
      status = "done"
      given {
        a governance repo using FSStore with 3 commits
      }
      when {
        mos vcs migrate --to git is run
      }
      then {
        all objects and refs are copied to .git/objects/ and refs/mos/*, config is updated, and verify passes
      }
    }

    scenario "migrate git to fs" {
      status = "done"
      given {
        a governance repo using GitStore with 3 commits
      }
      when {
        mos vcs migrate --to fs is run
      }
      then {
        all objects and refs are copied to .mos/store/ and .mos/refs/, config is updated, and verify passes
      }
    }
  }
  sprint = "SPR-2026-006"
}


specification "SPEC-2026-028" {
  title = "Agent-Ready Governance Gate — CLI Surface Specification"
  status = "active"
  slug = "agent-ready-gate-cli"
  justifies = "NEED-2026-002"
  addresses = ["C1", "C2", "C3", "C4", "C5"]
  enforcement = "warn"
  created_at = 2026-03-04T09:40:00Z
  updated_at = 2026-03-04T09:42:00Z
  description = "Formalizes the five acceptance criteria of NEED-2026-002 as testable CLI surface requirements. Each criterion maps to a specific mos command behavior that must be mechanically verifiable. This spec sits between the need and the implementing contracts, completing the derivation chain: Need -> Spec -> Contract."

  section "C1: One-shot project orientation" {
    text = """
mos status must output in a single invocation: active sprint (ID, title, progress), open contracts (ID, status, title), lint summary (error/warning/info counts), and harness results (pass/fail per rule). An agent calling mos status at session start gets full project context without additional commands."""
  }

  section "C2: Full artifact content rendering" {
    text = """
mos <kind> show <id> must render full artifact content by default: description, features with scenarios (given/when/then), sections with text, coverage blocks, and all metadata fields. A --short flag provides summary-only output. Agents must not need --verbose or raw file reads to inspect content."""
  }

  section "C3: CLI discoverability via help" {
    text = """
Every mos command and subcommand must respond to --help and -h with usage string, available flags with descriptions, and examples. Parent commands must list subcommands. Help must route correctly through the command hierarchy — a --help flag on a leaf command must not be intercepted by a parent dispatcher."""
  }

  section "C4: Mechanical lint enforcement" {
    text = """
mos lint must detect broken chains, orphan contracts, schema violations, slug collisions, lifecycle-chain gaps, and structural issues without requiring human judgment. Exit code must be non-zero when errors exist. Output must be parseable by agents for conditional branching."""
  }

  section "C5: Harness-based self-verification" {
    text = """
mos harness run must execute all configured mechanical rules and report pass/fail per rule with rule IDs and durations. The exit code must reflect overall pass/fail. Agents use this as a post-change verification gate — if harness passes, the change is mechanically sound."""
  }

  spec {
    include "cmd/mos"
    include "cmd/mos/factory"
  }
  state = "current"
  group = "cli"
}


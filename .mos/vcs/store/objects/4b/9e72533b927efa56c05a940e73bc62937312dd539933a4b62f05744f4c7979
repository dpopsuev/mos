blob
contract "CON-2026-142" {
  title = "Quality rules DSL: configurable per-vector metrics and thresholds"
  status = "complete"
  slug = "quality-rules-dsl"
  justifies = "NEED-2026-005"
  kind = "feature"
  goal = "Define a config block DSL within .mos/rules/mechanical/ that allows declaring quality metrics, thresholds (floor and ceiling), include/exclude patterns, language-specific overrides, and Blue/Red mode selection. The DSL is the single configuration surface for all three vectors. Ship opinionated defaults; allow full override."

  feature "Config block schema" {

    scenario "rule with config block is parsed and applied by the structural linter" {
      labels = ["happy_path"]
      actor = "agent"
      given {
        a rule with config block containing metric, ceiling, indent_unit, exclude
      }
      when {
        mos lint loads the rule
      }
      then {
        the structural linter applies the declared thresholds during analysis
      }
    }

    scenario "rule with floor and ceiling enforces bidirectional thresholds" {
      labels = ["happy_path"]
      actor = "contributor"
      given {
        a rule with floor 2 and ceiling 15 for exported_symbols_per_file
      }
      when {
        mos lint runs
      }
      then {
        files below floor get info diagnostics and files above ceiling get warnings
      }
    }
  }

  feature "Per-language overrides" {

    scenario "language-specific indent config overrides global default" {
      labels = ["happy_path"]
      actor = "contributor"
      given {
        a global rule with indent_unit tab
        a language override for *.py with indent_unit space and indent_size 4
      }
      when {
        mos lint runs on both Go and Python files
      }
      then {
        Go files are measured with tabs and Python files with 4 spaces
      }
    }
  }

  feature "Blue/Red mode selection" {

    scenario "rule declares red team mode for adversarial checks" {
      labels = ["happy_path"]
      actor = "contributor"
      given {
        a rule with mode red_team
      }
      when {
        mos ci runs
      }
      then {
        the rule is only executed during red team passes, not during fast CI
      }
    }
  }
  batch = "BAT-2026-007"
  sprint = "SPR-2026-014"
}


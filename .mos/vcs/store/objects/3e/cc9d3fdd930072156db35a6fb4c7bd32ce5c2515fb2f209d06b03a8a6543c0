contract "CON-2026-012" {
  title = "Contract Migration (Superseded)"
  status = "abandoned"
  goal = "Mos's 10 existing markdown contracts are represented in `.mos/` DSL format, created entirely via `mos contract create`, and validated by `mos lint .` with zero errors."

  coverage {

    unit {
      applies = false
      rationale = "Migration is a data transformation via CLI, not new library code."
    }

    integration {
      applies = true
      rationale = "Full pipeline: read markdown -> cst contract create -> cst lint -> verify cross-references."
    }

    contract {
      applies = false
      rationale = "No external API."
    }

    e2e {
      applies = true
      rationale = "All 10 contracts in .cst/ format, linted, cross-referenced, LSP-navigable."
    }

    concurrency {
      applies = false
      rationale = "Sequential migration."
    }

    security {
      applies = false
      rationale = "Local file operations only."
    }
  }

  feature "Contract Migration" {

    scenario "All contracts migrated to DSL format" {
      given {
        CON-2026-011 is complete (CLI commands exist, .cst/ scaffold exists)
        10 markdown contracts exist in contracts/
      }
      when {
        the agent reads each markdown file and calls cst contract create
      }
      then {
        10 contract artifacts exist in .cst/contracts/
        each contract preserves: status, goal, title, acceptance criteria, dependencies
        cst lint . passes with zero diagnostics
      }
    }

    scenario "Umbrella contract structure" {
      given {
        CON-2026-001 is the parent contract referencing 9 sub-contracts
      }
      when {
        it is migrated to .cst/ format
      }
      then {
        CON-2026-001 exists as an umbrella contract
        its scope.depends_on lists all sub-contract IDs
        the linter validates the umbrella structure
      }
    }

    scenario "Original markdown deleted" {
      given {
        all contracts are migrated to .cst/ format
      }
      when {
        migration is complete
      }
      then {
        no contracts/CON-2026-*.md files remain
        .cst/contracts/ is the single source of truth
      }
    }

    scenario "Cross-reference integrity" {
      given {
        contracts with depends_on references exist in .cst/
      }
      when {
        cst lint . is run
      }
      then {
        all depends_on references resolve to existing contracts
        no dangling references
      }
    }

    scenario "CLI-only constraint verified" {
      given {
        the migration is complete
      }
      when {
        the agent's command history is reviewed
      }
      then {
        every .cst/contracts/ file was produced by cst contract create
        no direct file writes to .cst/contracts/ occurred
      }
    }
  }
}


contract "CON-2026-160" {
  title = "Separate governance I/O from domain logic"
  status = "complete"
  created_at = 2026-03-04T18:44:00Z
  updated_at = 2026-03-04T18:44:00Z
  goal = "Introduce a Repository interface (or similar seam) in governance/ to abstract filesystem reads/writes. Production code uses os-backed implementation; tests can use in-memory fakes. Target: at most 5 production files import os directly (down from 20). WithArtifact stays as convenience but delegates to the interface."
  kind = "feature"

  acceptance {

    criterion "repository-interface" {
      description = "A Repository (or Storage) interface exists in governance/ abstracting file read/write/list operations"
    }

    criterion "os-import-cap" {
      description = "At most 5 governance/*.go production files import os directly (down from 20)"
    }

    criterion "in-memory-tests" {
      description = "At least one governance test file uses an in-memory Repository fake instead of temp directories"
    }

    criterion "build-clean" {
      description = "go build ./... and go test ./... pass with zero errors"
    }
  }
  sprint = "SPR-2026-014"
  slug = "separate-governance-io"
}


contract "CON-2026-121" {
  title = "Bulk operations: multi-ID commands"
  status = "draft"
  created_at = 2026-03-03T21:36:07Z
  updated_at = 2026-03-04T09:25:51Z
  batch = ""
  description = "All mutation commands (update, reclassify, delete) must accept multiple IDs in a single invocation. Currently assigning 10 contracts to a batch requires 10 separate CLI calls — an agent pays 10x the process spawn cost and token overhead. Examples: mos contract update --batch BAT-2026-006 CON-2026-111 CON-2026-112 ... or mos batch add CON-2026-111 CON-2026-112. Also applies to: mos contract update --status active CON-111 CON-112, mos rule import --sync advisory rule-a rule-b rule-c. Multi-ID is the difference between O(1) and O(n) for every triage, reclassification, and batch assignment operation."
  name = "Bulk operations: multi-ID commands"
  slug = "bulk-multi-id"

  feature "Multi-ID on update" {
  }

  feature "Multi-ID on status transitions" {
  }
}


contract "CON-2026-074" {
  title = "Git parity: tag"
  status = "complete"
  created_at = 2026-03-03T18:57:44Z
  updated_at = 2026-03-03T19:11:01Z
  goal = "Named immutable snapshots of governance state. Lightweight and annotated tags with optional signature. Reimplemented, no shelling out to git."
  justifies = "NEED-2026-001"
  batch = "BAT-2026-004"
  kind = "feature"
  slug = "git-tag"
  depends_on = "CON-2026-064"

  feature "tag" {

    scenario "create and list lightweight tags" {
      status = "done"
      given {
        a repo with commits
      }
      when {
        user creates tag v1.0 at HEAD
      }
      then {
        ListTags returns v1.0 pointing to HEAD commit
      }
    }

    scenario "delete tag" {
      status = "done"
      given {
        tag v1.0 exists
      }
      when {
        user deletes tag v1.0
      }
      then {
        tag is removed from store
      }
    }
  }
}


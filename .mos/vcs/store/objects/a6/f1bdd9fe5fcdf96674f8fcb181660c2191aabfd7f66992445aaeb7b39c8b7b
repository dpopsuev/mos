contract "CON-2026-071" {
  title = "Git parity: checkout / switch"
  status = "complete"
  created_at = 2026-03-03T18:57:44Z
  updated_at = 2026-03-03T19:10:53Z
  goal = "Switch between governance branches or restore artifacts to a prior state. Supports both branch switching and artifact-level restore. Reimplemented, no shelling out to git."
  justifies = "NEED-2026-001"
  batch = "BAT-2026-004"
  kind = "feature"
  slug = "git-checkout"
  depends_on = "CON-2026-070"

  feature "checkout" {

    scenario "switch to existing branch" {
      status = "done"
      given {
        branches main and feature exist
      }
      when {
        user checks out feature
      }
      then {
        symbolic HEAD points to feature and index matches its commit
      }
    }

    scenario "detach HEAD at hash" {
      status = "done"
      given {
        a commit hash
      }
      when {
        user checks out the hash
      }
      then {
        HEAD is detached and index matches that commit
      }
    }
  }
}


contract "CON-2026-144" {
  title = "Unify governance and linter schema systems to eliminate parallel ArtifactTypeDef/CustomArtifactSchema"
  status = "complete"
  created_at = 2026-03-04T16:00:07Z
  updated_at = 2026-03-04T16:00:07Z
  goal = "The governance package defines ArtifactTypeDef with FieldDef (Link, RefKind, Transitions, etc.) and the linter defines CustomArtifactSchema with CustomFieldSchema. These are parallel representations that must stay in sync manually. The root cause is a circular dependency: governance imports linter, so linter cannot import governance. Extract a shared schema interface package (e.g. moslib/schema) that both can import, or invert the dependency so governance does not import linter. This eliminates the duplicated types and ensures link field metadata, lifecycle hooks, and urgency propagation flow from a single definition."
  kind = "feature"
  justifies = "NEED-2026-002"
  sprint = "SPR-2026-014"
  slug = "unify-schema-systems"
}


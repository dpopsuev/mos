  goal = "Add mos archive CLI command for moving artifacts from active/ to archive/, replacing manual mv loops"
  justifies = "NEED-2026-001"
  kind = "feature"

  feature "Verb-first archive command" {

    scenario "archive single artifact by ID" {
      given = "a contract with terminal status in active/"
      when = "mos archive CON-2026-XXX is run"
      then = "the artifact directory moves from active/ to archive/"
    }

    scenario "archive all terminal artifacts" {
      given = "multiple artifacts with terminal status in active/"
      when = "mos archive --all-terminal is run"
      then = "all terminal artifacts are moved to archive/ via RelocateMisplacedArtifacts"
    }
  }
  sprint = "SPR-2026-037"
}


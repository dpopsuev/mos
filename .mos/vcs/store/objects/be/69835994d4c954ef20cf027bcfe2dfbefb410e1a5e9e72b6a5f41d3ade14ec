contract "CON-2026-138" {
  title = "Functional vector: batteries-included harness verification"
  status = "complete"
  slug = "functional-vector"
  justifies = "NEED-2026-005"
  kind = "feature"
  goal = "Provide zero-config Functional verification for both Blue and Red modes. Blue: Gherkin scenario execution, test matrix reporting, acceptance criteria coverage. Red: mutation testing integration, fuzz seed discovery, negative-path scenario generation. Ship default rules that run Go tests and report coverage; allow override for other languages via rule DSL."

  feature "Blue Team: test execution and coverage" {

    scenario "mos ci runs Go tests and reports pass/fail with coverage" {
      labels = ["happy_path"]
      actor = "agent"
      given {
        a Go project with test files
        no custom functional rules configured
      }
      when {
        mos ci runs the functional vector
      }
      then {
        go test is executed with coverage and results are reported per-package
      }
    }

    scenario "Gherkin scenarios in contracts are verified against test results" {
      labels = ["happy_path"]
      actor = "agent"
      given {
        a contract with 3 scenarios marked done
        corresponding test functions exist
      }
      when {
        mos ci runs the functional vector
      }
      then {
        the test matrix shows 3/3 scenarios covered
      }
    }
  }

  feature "Red Team: adversarial functional verification" {

    scenario "mutation testing detects undertested code" {
      labels = ["red_team"]
      actor = "agent"
      given {
        a Go package with 90 percent line coverage but weak assertions
      }
      when {
        mos ci runs functional red mode
      }
      then {
        mutation score is reported and weakly tested functions are flagged
      }
    }
  }

  feature "Language-agnostic configuration" {

    scenario "user configures functional vector for Python" {
      labels = ["happy_path"]
      actor = "contributor"
      given {
        a rule in .mos/rules/mechanical/ with metric functional and command pytest
      }
      when {
        mos ci runs the functional vector
      }
      then {
        pytest is executed instead of go test
      }
    }
  }
  batch = "BAT-2026-007"
  sprint = "SPR-2026-032"
}


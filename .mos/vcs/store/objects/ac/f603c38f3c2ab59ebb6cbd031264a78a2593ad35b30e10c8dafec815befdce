rule "benchmarks-regression" {
  name = "Benchmark Regression Detection"
  type = "mechanical"
  scope = "project"
  enforcement = "warning"
  vector = "performance"

  harness {
    command = "go test -bench=. -benchmem -run=^$ ./..."
    timeout = "10m"

    metric "ns_op" {
      unit = "ns"
    }

    metric "allocs_op" {
      unit = "allocs"
    }
  }
}

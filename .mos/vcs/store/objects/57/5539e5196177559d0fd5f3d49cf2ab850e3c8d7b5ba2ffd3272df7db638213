contract "CON-2026-099" {
  title = "CON-2026-099"
  status = "abandoned"
  created_at = 2026-03-03T21:06:17Z
  updated_at = 2026-03-03T21:26:42Z
  slug = "rule-import-fork-sync"
  description = "Import rules from external mos repositories with three sync levels per the Manifesto Fork Sync Protocol: isolated (one-time copy, no provenance), advisory (upstream drift surfaces as lint warnings), full (changes propagate automatically). Supports importing individual rules or named packs defined by upstream owners. Local overrides always allowed — defaults not mandates."
  name = "Rule Import with Fork Sync Protocol"

  feature "Import rules from git" {

    scenario "--scenario" {
      given {
        A rule imported with full sync
      }
      when {
        Upstream publishes a new version
      }
      then {
        mos sync pulls the update and applies it; local changes are logged as informational
      }
    }
  }
}


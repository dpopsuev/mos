contract "CON-2026-215" {
  title = "CLI: mos harness maquette -- iterative metric parser playground with history and promotion"
  status = "complete"
  created_at = 2026-03-05T15:54:42Z
  updated_at = 2026-03-05T15:54:42Z
  goal = "Add a 'mos harness maquette' subcommand for iterative metric parser development. Each invocation takes a pattern (regex or json_path), input source (--input string, --file path, or --stdin), and optional threshold (--ceiling, --floor, --unit). It extracts the value, prints pass/fail verdict, and saves the run to .mos/maquettes/ as a JSON history entry (index 0 = latest, previous entries shift up). Users can review history with --history, and promote a validated maquette into a rule's harness block with --save <index> --name <metric_name> --rule <rule_id>. Supports both stdout regex and JSON file modes. Designed for both human and agentic workflows: an AI agent can feed a sample output file, iterate on patterns in a tight loop (~500ms per call vs full benchmark suite), use history for backtracking, and promote the best match -- turning regex authoring from guesswork into a convergent search. All output is machine-parseable (--format json) for programmatic consumption."
  priority = "p3"

  scope {
    depends_on = ["CON-2026-213"]
  }
  sprint = "SPR-2026-023"
}


%% Mos 3-Tool Desired Architecture
%% Updated: 2026-03-05 (SPR-2026-018 — CLI reorganization complete)
%%
%% Golden Rule: artifact/ is the ONLY package that touches .mos/ filesystem.
%% Layer Rule: sub-tools depend downward only, never upward or sideways.
%% Interface A (Insight -> Govern): artifact.Create(), artifact.Read(), artifact.Query(), artifact.FindPath()
%% Interface B (Guard -> Govern): artifact.Read(), artifact.Query(), registry.LoadSchemas()

graph TD
  subgraph layer0 [Layer 0 — Foundation]
    dsl["dsl/"]
    schema["schema/"]
    store["store/"]
    model["model/"]
    names["names/"]
  end

  subgraph layer1 [Layer 1 — Govern Core]
    artifact["artifact/ — CRUD, query, lifecycle"]
    registry["registry/ — type definitions"]
  end

  subgraph layer2 [Layer 2 — Domain]
    subgraph insightPkgs [Insight — understand]
      survey["survey/"]
      arch["arch/ — sync + specgen + drift"]
      meshLib["mesh/ — resolve + render"]
      cloneLib["clone/"]
      topology["topology/"]
    end
    subgraph guardPkgs [Guard — protect]
      linter["linter/"]
      harness["harness/"]
      vcs["vcs/"]
      ci["ci/"]
      audit["audit/"]
      guard["guard/ — PreCommitChecker"]
    end
  end

  subgraph layer3 [Layer 3 — CLI]
    cmdGovern["cmd/govern/ — show, get, set, query, create, status, init, fmt, migrate"]
    cmdInsight["cmd/insight/ — mesh, clone, survey, specgen"]
    cmdGuard["cmd/guardcmd/ — audit, lint, harness"]
  end

  artifact --> dsl
  artifact --> schema
  artifact --> store
  artifact --> names
  registry --> schema
  registry --> names

  insightPkgs -->|"Interface A: Read + Write"| artifact
  guardPkgs -->|"Interface B: Read + Check"| artifact
  arch --> survey
  vcs -->|"via guard.PreCommitChecker"| linter

  cmdGovern --> artifact
  cmdInsight --> arch
  cmdInsight --> meshLib
  cmdInsight --> cloneLib
  cmdGuard --> linter
  cmdGuard --> vcs
  cmdGuard --> audit

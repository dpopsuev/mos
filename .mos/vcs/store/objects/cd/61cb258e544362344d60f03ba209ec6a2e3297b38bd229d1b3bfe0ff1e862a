contract "CON-2026-999" {
  title = "Production Ready -- End of Days"
  status = "draft"
  justifies = "NEED-2026-001"
  goal = "An end-user can clone Mos repositories from the Senate forge, launch a Magis-compatible UI (TUI or enterprise GUI), choose local or remote execution mode, and have an Origami-orchestrated LLM agent swarm on Kubernetes execute governance workflows across multiple repositories while the human operator retains interrupt authority and workload observability at all times."

  coverage {

    unit {
      applies = true
      rationale = "Embassy adapter, sync protocol, interrupt handler, RBAC policy evaluation, KEDA metric exporter, governance graph cache, conflict serializer."
    }

    integration {
      applies = true
      rationale = "Magis Server <-> Senate forge (git push/pull), Magis Server <-> agent pods (NetworkDispatcher), Magis Server <-> KEDA (Prometheus metrics), GUI <-> Magis Server (protocol)."
    }

    contract {
      applies = true
      rationale = "Magis client-server protocol schema (TUI and GUI must be interchangeable). Origami Component interface compliance. Embassy adapter interface. RBAC role definitions."
    }

    e2e {
      applies = true
      rationale = "Full dog-food cycle: clone -> connect -> circuit -> agents -> interrupt -> sync -> validate. Multi-user scenario: 2 operators, 5 agents, 3 repos, 1 interrupt."
    }

    concurrency {
      applies = true
      rationale = "Multiple operators writing to the same repo via Magis Server (serialization). Multiple agent pods consuming from MuxDispatcher (work stealing). KEDA scale-up during active circuit (pod startup race). Sync tick racing with in-flight writes."
    }

    security {
      applies = true
      rationale = "Multi-tenant isolation. Credential management (LLM API keys, git SSH keys, SSO tokens). Network policies (agent pods cannot reach the internet except LLM endpoints). Agent trust boundary (agents cannot ratify or override governance)."
    }
  }

  feature "Production Ready -- End of Days" {

    scenario "Senate forge hosts Mos repositories" {
      given {
        a Gitea/Forgejo instance deployed on Kubernetes via Helm
        an organization "acme" with 3 Mos repositories
      }
      when {
        a developer clones "acme/service-a" from the Senate
      }
      then {
        the clone contains a valid .mos/ directory
        "mos lint ." passes on the local clone
        the Senate web UI renders .mos/ artifacts (rules, contracts, vocabulary)
        the governance graph is discoverable from any of the 3 repos
      }
    }

    scenario "Magis Server runs on Kubernetes with session persistence" {
      given {
        a Magis Server StatefulSet deployed on Kubernetes
        the server is configured with repos "acme/service-a" and "acme/service-b"
      }
      when {
        an operator connects via Magis TUI
        the operator opens a file and starts editing
        the TUI client crashes
      }
      then {
        the Magis Server continues running
        any active agent circuits continue executing
        when the operator reconnects, editor buffers are preserved
        the session state survives pod restarts (persistent volume)
      }
    }

    scenario "Local mode: operator uses own LLM agent swarm" {
      given {
        a developer with Ollama running locally
        a local clone of "acme/service-a" from the Senate
      }
      when {
        the developer launches Magis and selects "local mode"
      }
      then {
        Magis runs as a local process on localhost
        reads and writes both happen locally
        Origami ProviderRouter dispatches to local Ollama
        "mos" CLI operates on local .mos/ artifacts
        no connection to a remote Magis Server is required
      }
    }

    scenario "Remote mode: reads local, writes remote, loop closes" {
      given {
        a Magis Server on Kubernetes with "acme/service-a" mounted
        an operator with a local clone of "acme/service-a"
      }
      when {
        the operator connects to the remote Magis Server
        the operator triggers a governance circuit that modifies 3 files
      }
      then {
        the operator reads file contents from the local clone (fast, offline-capable)
        all 3 file modifications go through the Magis Server
        the Magis Server commits and pushes to the Senate forge
        the local clone syncs via "git pull" on the next sync tick
        after sync, the local clone reflects all 3 modifications
        "mos lint ." passes on both the server and the local clone
      }
    }

    scenario "Human operator sends interrupt during agent execution" {
      given {
        a Magis Server with 10 agent pods executing a governance circuit
        the circuit has 50 pending steps in the MuxDispatcher queue
      }
      when {
        the operator sends a HALT interrupt
      }
      then {
        all 10 agents complete their current step (no mid-step abort)
        no new steps are picked up from the queue
        the operator sends an INSPECT command and receives:
        10 agents (all idle after completing current step)
        50 pending steps (unchanged)
        0 in-flight steps
        the operator sends RESUME and agents pick up work again
      }
    }

    scenario "Origami autoscales agent pods based on workload" {
      given {
        a KEDA ScaledObject monitoring origami_dispatch_queue_depth
        the minimum agent pod count is 0
        the maximum agent pod count is 20
      }
      when {
        an operator triggers a circuit with 100 cases
        the MuxDispatcher queue depth reaches 100
      }
      then {
        KEDA scales agent pods from 0 toward the maximum
        agent pods connect to the Magis Server's NetworkServer
        agent pods consume work from the MuxDispatcher
        as queue depth decreases, KEDA scales down
        scale-down respects graceful termination (agents finish current step)
        when queue depth reaches 0 and all cases are complete, pods scale to 0
      }
    }

    scenario "Enterprise GUI provides governance dashboard" {
      given {
        an enterprise GUI connected to the Magis Server
        an operator authenticated via SSO with role "senator"
      }
      when {
        the operator opens the governance dashboard
      }
      then {
        all Senate repositories are visible with governance status
        drift between desired and concrete state is highlighted
        harness compliance (pass/fail) is shown per repo
        active agent circuits are listed with progress indicators
        the audit log shows all recent governance actions with attribution
      }
    }

    scenario "RBAC enforces governance authority boundaries" {
      given {
        user "alice" with role "senator" (full governance authority)
        user "bob" with role "assistant" (draft only, no ratification)
        user "charlie" with role "observer" (read-only)
      }
      when {
        bob drafts a Bill to amend a standing rule
        bob attempts to ratify the Bill
      }
      then {
        the draft succeeds (within bob's authority)
        the ratification is rejected ("assistant" role cannot ratify)
        alice can ratify the Bill
        charlie can view the Bill and its history but cannot modify anything
      }
    }

    scenario "Federation works across multiple Senate instances" {
      given {
        Senate instance "senate-a" hosting organization "alpha" with 5 repos
        Senate instance "senate-b" hosting organization "beta" with 3 repos
        "beta/lib-shared" has an upstream block pointing at "alpha/platform"
      }
      when {
        an agent crawls the governance graph starting from "beta/lib-shared"
      }
      then {
        the crawler discovers "alpha/platform" across Senate instances
        the full governance graph includes all 8 repos
        upstream chains are resolved across instances
        cross-repo includes between instances resolve correctly
        "mos lint ." passes with the federated workspace loaded
      }
    }

    scenario "Dog-food: Mos governs itself in production" {
      given {
        Mos's own repositories hosted on a Senate instance
        a Magis Server deployed on Kubernetes
        a KEDA ScaledObject configured for agent autoscaling
      }
      when {
        a developer clones Mos from the Senate
        the developer launches Magis TUI and connects to the remote Magis Server
        the developer triggers "mos harness run ." via a governance circuit
      }
      then {
        the Origami circuit orchestrates harness execution across all Mos repos
        KEDA scales agent pods to handle the workload
        the developer sends INSPECT and sees all active agents and their progress
        the circuit completes with all harness rules passing
        the local clone syncs and reflects any agent-produced artifacts
        "mos lint ." passes on all repos
        the full cycle (clone, connect, circuit, agents, interrupt, sync, validate) works end-to-end
      }
    }
  }

  scope {
    depends_on = [
      "CON-2026-016",
      "CON-2026-017",
      "CON-2026-018",
      "CON-2026-020",
      "CON-2026-023",
    ]
  }

need "NEED-2026-002" {
  title = "Agent-Ready Governance Gate"
  status = "addressed"
  sensation = "Agents begin every session blind. Without a structured governance gate — orientation, discoverability, acceptance criteria, mechanical enforcement, self-verification — each agent wastes tokens re-discovering project state, guessing at commands, and declaring work done without proof. OpenAI, Anthropic, and LangChain all independently built bespoke harnesses to solve this. Mos must provide this as a reusable framework: the minimum viable loop where an agent can orient, understand the work, execute, verify, and hand off cleanly."
  slug = "agent-ready-gate"
  urgency = "critical"

  scope {
    includes = [
      "one-shot project orientation",
      "full artifact content rendering",
      "CLI discoverability via --help",
      "mechanical lint enforcement",
      "harness-based self-verification",
      "clean session handoff",
    ]
    excludes = [
      "cross-repo federation",
      "signed hash chain",
      "TUI (Curia)",
      "LSP server",
      "multi-model orchestration",
      "domain-specific harnesses",
    ]
  }

  acceptance {

    criterion "C1" {
      description = "mos status orients an agent in one shot: active sprint, open contracts, recent lint summary, drift snapshot"
      verified_by = "harness"
      contract = "CON-2026-111"
    }

    criterion "C2" {
      description = "mos contract show renders full content by default: description, features, scenarios with Given/When/Then, all metadata"
      verified_by = "harness"
      contract = "CON-2026-115"
    }

    criterion "C3" {
      description = "Every mos command and subcommand responds to --help / -h with usage, flags, and examples; help routes correctly through the hierarchy"
      verified_by = "harness"
      contract = "CON-2026-114"
    }

    criterion "C4" {
      description = "mos lint detects broken chains, orphans, schema violations, and structural issues without human judgment"
      verified_by = "linter"
    }

    criterion "C5" {
      description = "mos harness run executes mechanical rules and reports pass/fail per rule, enabling agent self-verification"
      verified_by = "harness"
    }
  }

  section "Evidence" {
    text = "Three independent case studies (OpenAI Codex, Anthropic Claude, LangChain) converge on the same five capabilities as prerequisites for agent-driven development. See BND-2026-001 (Harness Engineering Case Studies) for full analysis. SPEC-2026-030, SPEC-2026-031, SPEC-2026-032."
  }

  section "PoC Gate" {
    text = "An AI agent can: (1) run mos status to orient, (2) read a contract to understand acceptance criteria, (3) discover commands via --help, (4) execute work and verify via mos lint and mos harness run, (5) leave .mos/ in a clean state for the next session. When all five criteria pass, the PoC is complete."
  }
}


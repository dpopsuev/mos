  goal = "Add mos query -- a read-only graph traversal command that subsumes filtered list, reverse references, cross-type search, and stats. Supports: (1) filtered list via mos query --kind contract --status draft --labels dogfood, (2) reverse reference via mos query --references NEED-2026-001 to find all artifacts that justify/implement/document a target, (3) cross-type search across needs+specs+contracts+architectures+docs in one pass, (4) count/stats via --count and --group-by status. Then add mos update --stdin to accept IDs from a query pipe, enabling bulk mutations like mos query --kind contract --status draft | mos update --stdin --justifies NEED-2026-001. This replaces the original narrow scope of bulk field operations with the general-purpose query primitive that the system compiler needs."
  labels = ["feature", "cli", "bulk"]
}


blob
contract "CON-2026-034" {
  title = "Dunix Scenario"
  status = "draft"
  created_at = 2026-03-03T14:47:40Z
  updated_at = 2026-03-03T19:10:45Z
  goal = "Define the 5-era Dunix scenario from lore as structured milestone events. Each milestone maps to a specific tick and triggers site/repo/governance state changes."
  labels = ["dogfood", "simulation", "dunix"]
  parent = "CON-2026-029"

  feature "Era I: Genesis (ticks 0-1825)" {

    scenario "Genesis bootstrap" {
      status = "pending"
      given {
        a fresh simulation
      }
      when {
        the Genesis milestone fires at tick 0
      }
      then {
        Terra site is created with 3 teams and 15 engineers
        4 repos are created: dunix-kernel, dunix-userspace, dunix-net, dunix-hab
        locale is TerranEnglish
      }
    }

    scenario "Mars colony joins" {
      status = "pending"
      given {
        Genesis has completed
      }
      when {
        the NewSiteJoins milestone fires at tick 365
      }
      then {
        Mars site is created with 1 team and 6 engineers
        Mars clones all 4 repos
        Earth-Mars latency is 14 ticks
      }
    }

    scenario "Luna relay station" {
      status = "pending"
      given {
        Terra and Mars are active
      }
      when {
        the NewSiteJoins milestone fires at tick 1095 for Luna
      }
      then {
        Luna site is created with role arbiter
        Luna has 0 repos but runs linter
        Earth-Luna latency is 1 tick
      }
    }

    scenario "USSN adopts Dunix" {
      status = "pending"
      given {
        civilian Dunix repos exist on Terra
      }
      when {
        the MilitaryAdoption milestone fires at tick 1095 for USSN
      }
      then {
        USSN forks dunix-kernel and dunix-net into ussn-kernel and ussn-fleetcom
        both repos have compartment blocks with clearance secret
        artifacts are opaque to civilian operators
      }
    }
  }

  feature "Era II: The Divergence (ticks 1825-7300)" {

    scenario "MartianEnglish locale emerges" {
      status = "pending"
      given {
        Mars has 20+ engineers
      }
      when {
        LocaleCreation fires at tick 1825
      }
      then {
        MartianEnglish is registered
        Mars artifacts use mandate instead of contract
      }
    }

    scenario "Mars forks dunix-net" {
      status = "pending"
      given {
        Mars and Terra disagree on networking architecture
      }
      when {
        RepoFork fires at tick 4380
      }
      then {
        mars-net repo is created on Mars
        dunix-net continues on Terra
        both repos share git history up to the fork point
      }
    }

    scenario "SRJSN adopts Dunix" {
      status = "pending"
      given {
        the USSN already operates compartmented repos
      }
      when {
        the MilitaryAdoption milestone fires at tick 2555 for SRJSN
      }
      then {
        SRJSN establishes Tiangong-Ares station at Mars L1
        SRJSN forks Dunix with chain-of-command governance
        6 hierarchical clearance levels are defined
        commanding officer ratifies by seal, no voting
      }
    }

    scenario "Mars reaches code parity" {
      status = "pending"
      given {
        the simulation has run for 7300 ticks
      }
      when {
        commit volumes are compared
      }
      then {
        Mars commit count is within 10% of Terra commit count
        5 distinct governance models exist (sync, async, belt-oral, USSN hierarchy, SRJSN chain-of-command)
      }
    }
  }

  feature "Era III: The Outer Expansion (ticks 7300-18250)" {

    scenario "Kernel Schism" {
      status = "pending"
      given {
        Mars proposes capability-based IPC
      }
      when {
        Schism fires at tick 8030
      }
      then {
        mars-kernel repo is forked from dunix-kernel
        topology.Secede is invoked
        two incompatible kernel lines exist
      }
    }

    scenario "Ceres Leak triggers Opaque Reference Protocol" {
      status = "pending"
      given {
        Belt civilian engineers and USSN compartmented artifacts coexist in the federation graph
      }
      when {
        the Incident fires at tick 9125
      }
      then {
        a linter crash is triggered by cross-ref to a compartmented artifact
        the Opaque Reference Protocol is adopted: exists: true, clearance: denied
        linter skips content validation on opaque refs
        governance graph edges are still tracked
      }
    }

    scenario "SRJSN establishes Zvezdny" {
      status = "pending"
      given {
        Ganymede station comes online at tick 10950
      }
      when {
        SRJSN MilitaryAdoption fires at tick 10950 for Zvezdny
      }
      then {
        Zvezdny station is created in Ganymede orbit
        15 SRJSN engineers begin operations
        Zvezdny uses chain-of-command governance
      }
    }

    scenario "Grand Schism" {
      status = "pending"
      given {
        3 sites with incompatible kernels and networking stacks
      }
      when {
        Schism fires at tick 12775
      }
      then {
        cross-site justifies links break
        linter reports dangling cross-site references
      }
    }

    scenario "Accord of Ceres" {
      status = "pending"
      given {
        the Grand Schism has occurred
      }
      when {
        the Accord fires at tick 13870
      }
      then {
        federation schema is adopted (site:ID notation)
        Luna is designated arbiter
        cross-site links are repaired using canonical IDs
      }
    }

    scenario "Phobos War -- catastrophic data loss" {
      status = "pending"
      given {
        USSN hosts 3 compartmented repos exclusively on Phobos relay
        no off-site backups exist due to compartmentalization rules
      }
      when {
        the War event fires at tick 15330
      }
      then {
        Phobos relay is destroyed
        3 USSN repos are permanently lost (847 artifacts, 2 years of patches)
        the Disaster Recovery Amendment is triggered
        dead mans key protocol is adopted: Luna holds encrypted metadata
        N+1 redundancy becomes mandatory for all sites
      }
    }

    scenario "Mars kernel reunification" {
      status = "pending"
      given {
        mars-kernel has been separate for 23 simulated years
      }
      when {
        Union fires at tick 16425
      }
      then {
        topology.Union merges mars-kernel back
        capability model wins, POSIX shim becomes first-class
        4000+ artifacts are reconciled
        340 orphan needs are retired
      }
    }
  }

  feature "Era IV: The Deep Reach (ticks 18250-36500)" {

    scenario "Titan philosophical secession" {
      status = "pending"
      given {
        Titan station exists with Titanese locale
      }
      when {
        Schism fires at tick 21900
      }
      then {
        Titanos fork is created (ABI compatible, governance independent)
        reflection block becomes mandatory on Titan for critical-urgency needs
      }
    }

    scenario "Enceladus Incident and USSN declassification" {
      status = "pending"
      given {
        dunix-conscience had flagged a critical warning 180 ticks prior
        the warning was ignored
        USSN has been running classified ussn-conscience for 10 years
      }
      when {
        the Incident fires at tick 23725
      }
      then {
        urgency propagation goes federation-wide
        all sites adopt reflection blocks on critical-urgency needs
        the Enceladus Index spikes
        USSN declassifies ussn-conscience via compartment.declassify
        previously opaque artifacts become visible to civilians
        the sealed audit chain is preserved through declassification
      }
    }

    scenario "USSN establishes Vesta" {
      status = "pending"
      given {
        Miranda station comes online at tick 27375
      }
      when {
        USSN MilitaryAdoption fires at tick 27375 for Vesta
      }
      then {
        Vesta station is created in the Belt
        25 USSN engineers begin operations
        Vesta uses compartmentalized hierarchy governance
      }
    }

    scenario "Miranda speculative merge" {
      status = "pending"
      given {
        Miranda station exists with 12+ hour review cycles
      }
      when {
        ProtocolInnovation fires at tick 29200
      }
      then {
        speculative merge protocol is enabled on Miranda
        Miranda can push with speculative = true and deploy locally
        upstream rejection triggers rollback
      }
    }

    scenario "The Quiet War -- governance graph corruption" {
      status = "pending"
      given {
        SRJSN operates repos at Tiangong-Ares and Zvezdny
        all SRJSN artifacts have sealed governance chains
      }
      when {
        the War event fires at tick 31025
      }
      then {
        40% of SRJSN cross-reference links are corrupted
        justifies and implements links point to wrong targets
        the governance graph is semantically poisoned
        sealed governance chains enable reconstruction by walking seal chain backwards
        recovery takes approximately 120 ticks (4 months)
        federation-wide sealed governance chains (merkle root in seals) are adopted
      }
    }
  }

  feature "Era V: The Edge (ticks 36500-54750)" {

    scenario "Triton hermetic protocol" {
      status = "pending"
      given {
        Triton station with 4 engineers and 280-tick delay to Terra
      }
      when {
        NewSiteJoins fires at tick 36500
      }
      then {
        Triton uses hermetic protocol (unanimous 4-person decisions)
        syncs upstream in daily batches
        Tritonic locale is registered with 12 governance keywords
      }
    }

    scenario "Solar Census at tick 43800" {
      status = "pending"
      given {
        the simulation has reached tick 43800 (year 120)
      }
      when {
        a census is taken
      }
      then {
        14 sites (10 civilian + 4 military)
        63 repos (52 civilian + 11 military)
        742 engineers (602 civilian + 140 military)
        7 locales, 8 governance models (6 civilian + 2 military)
      }
    }

    scenario "Grand Union with Compartmentalization Annex" {
      status = "pending"
      given {
        all 14 sites are active (10 civilian + 4 military)
      }
      when {
        the Accord fires at tick 47450
      }
      then {
        Solar Compact is ratified
        every site keeps its locale and governance model
        Compartmentalization Annex is included
        civilian federation formally acknowledges opaque nodes
        linter skips content of compartmented artifacts
        canonical IDs work across the clearance boundary
        declassification has a formal protocol
        dead mans keys are mandatory for all compartmented repos
      }
    }

    scenario "Steady state at tick 54750" {
      status = "pending"
      given {
        the simulation has reached tick 54750 (year 150)
      }
      when {
        final metrics are collected
      }
      then {
        100+ repos, 1000+ engineers
        longest traceability chain spans 5 sites and 3 locales
        federation-wide linter time is recorded
        military sites contribute 15+ compartmented repos as opaque nodes
        Enceladus Index is computed federation-wide
        sealed governance chains are standard on every artifact
      }
    }
  }
  batch = "BAT-2026-002"
  slug = "dunix-scenario"
}


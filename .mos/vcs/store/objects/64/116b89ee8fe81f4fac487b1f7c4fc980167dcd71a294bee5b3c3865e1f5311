contract "CON-2026-060" {
  title = "Git parity: init"
  status = "complete"
  created_at = 2026-03-03T18:56:57Z
  updated_at = 2026-03-03T19:10:52Z
  goal = "Initialize a governance repository with full git-init parity. Create .mos/ structure, default config, HEAD-equivalent ref. Reimplemented, no shelling out to git."
  justifies = "NEED-2026-001"
  batch = "BAT-2026-004"
  kind = "feature"
  slug = "git-init"
  depends_on = "CON-2026-136"

  feature "Repository initialization" {

    scenario "default init" {
      status = "done"
      given {
        an empty directory
      }
      when {
        mos vcs init is run
      }
      then {
        .mos/ structure is created with default config and an empty index
      }
    }

    scenario "init with git backend" {
      status = "done"
      given {
        an empty directory with a .git/ repository
      }
      when {
        mos vcs init --store git is run
      }
      then {
        config.mos sets object_store.backend = git and refs/mos/ namespace is created in .git/
      }
    }
  }
  sprint = "SPR-2026-006"
}


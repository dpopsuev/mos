architecture "ARCH-desired" {
  title = "Mos 3-Tool Desired Architecture"
  status = "active"
  resolution = "package"

  layer "Foundation" {
    level = "0"
    packages = "dsl, schema, store, model, names"
  }

  layer "Govern Core" {
    level = "1"
    packages = "artifact, registry"
  }

  layer "Domain" {
    level = "2"
    packages = "linter, harness, vcs, survey, arch, mesh, clone, topology, guard"
  }

  layer "CLI" {
    level = "3"
    packages = "cmd/govern, cmd/insight, cmd/guard"
  }

  sub_tool "Govern" {
    packages = "artifact, registry, config"
  }

  sub_tool "Insight" {
    packages = "survey, arch, mesh, clone, topology"
  }

  sub_tool "Guard" {
    packages = "linter, harness, vcs, ci, audit, guard"
  }

  exception "vcs-linter" {
    from = "vcs"
    to = "linter"
    via = "guard.PreCommitChecker"
  }

  exception "arch-survey" {
    from = "arch"
    to = "survey"
  }

  section "Golden Rule" {
    text = "artifact/ is the ONLY package that touches the .mos/ filesystem. Everything else goes through its API."
  }

  section "Interfaces" {
    text = "Interface A (Insight -> Govern): artifact.Create, artifact.Read, artifact.Query, artifact.FindPath. Interface B (Guard -> Govern): artifact.Read, artifact.Query, registry.LoadSchemas."
  }
}


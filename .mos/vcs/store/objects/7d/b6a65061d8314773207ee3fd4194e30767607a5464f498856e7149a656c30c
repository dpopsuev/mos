contract "CON-2026-130" {
  title = "Gherkin personas: actor field and personas declaration block"
  status = "complete"
  slug = "gherkin-personas"
  justifies = "SPEC-2026-028"
  sprint = "SPR-2026-005"
  batch = "BAT-2026-006"
  goal = "Specifications and contracts currently lack structured actor information. Scenarios describe what happens but not who initiates the action. This makes adversarial testing vague, authority-system coverage unverifiable, and Origami persona mapping impossible. Add an 'actor' field on scenarios (zero new DSL keywords — same mechanism as sut/test/case) and a 'personas' declaration block on artifacts (same mechanism as coverage/scope). The linter cross-references actor values against declared personas. This keeps the reserved primitive count at 22 while adding semantic richness for role-based testing."
  created_at = 2026-03-04T14:00:00Z
  updated_at = 2026-03-04T11:12:39Z

  feature "Actor field on scenarios" {

    scenario "Actor accessor returns declared actor" {
      labels = ["happy_path"]
      given {
        a scenario with actor = "contributor"
      }
      when {
        Actor() is called on the parsed Scenario
      }
      then {
        it returns "contributor"
      }
    }

    scenario "Actor accessor returns empty when absent" {
      labels = ["happy_path"]
      given {
        a scenario with no actor field
      }
      when {
        Actor() is called
      }
      then {
        it returns an empty string
      }
    }

    scenario "ScenarioInfo includes actor" {
      labels = ["happy_path"]
      given {
        a contract with scenarios that have actor fields
      }
      when {
        ListScenarios is called
      }
      then {
        each ScenarioInfo.Actor contains the declared actor value
      }
    }
  }

  feature "Personas declaration block" {

    scenario "Personas parsed from artifact" {
      labels = ["happy_path"]
      given {
        a specification with a personas block declaring contributor, maintainer, and attacker
      }
      when {
        the DSL is parsed
      }
      then {
        the personas block is accessible as a standard Block node with three Field children
      }
    }

    scenario "Personas on contracts" {
      labels = ["happy_path"]
      given {
        a contract with a personas block
      }
      when {
        the DSL is parsed
      }
      then {
        the personas block is accessible in the same way as on specifications
      }
    }
  }

  feature "Linter cross-references actor against personas" {

    scenario "Actor matches declared persona" {
      labels = ["happy_path"]
      given {
        an artifact with personas block declaring "maintainer"
        and a scenario with actor = "maintainer"
      }
      when {
        the linter runs
      }
      then {
        no diagnostic is emitted for that scenario
      }
    }

    scenario "Actor does not match any declared persona" {
      labels = ["sad_path"]
      given {
        an artifact with personas block declaring "maintainer" and "contributor"
        and a scenario with actor = "attacker"
      }
      when {
        the linter runs
      }
      then {
        a warning diagnostic is emitted: actor "attacker" not declared in personas block
      }
    }

    scenario "Actor used but no personas block exists" {
      labels = ["sad_path"]
      given {
        a contract with no personas block
        and a scenario with actor = "admin"
      }
      when {
        the linter runs
      }
      then {
        an info diagnostic is emitted: scenario uses actor but artifact has no personas declaration
      }
    }

    scenario "Feature has scenarios but no actor on any" {
      labels = ["sad_path"]
      given {
        a specification with a personas block
        and a feature where no scenario has an actor field
      }
      when {
        the linter runs
      }
      then {
        an info diagnostic is emitted: feature has no actor coverage despite personas being declared
      }
    }
  }

  feature "Authority system persona coverage" {

    scenario "Every authority role has at least one scenario testing it" {
      labels = ["happy_path"]
      given {
        config.mos declares authority roles: contributor, maintainer, admin
        and specifications with actor fields covering all three roles
      }
      when {
        the linter runs authority coverage check
      }
      then {
        no diagnostic is emitted — all roles are covered
      }
    }

    scenario "Authority role missing from scenario actors" {
      labels = ["sad_path"]
      given {
        config.mos declares authority roles: contributor, maintainer, admin
        and specifications only have actors "contributor" and "maintainer"
      }
      when {
        the linter runs authority coverage check
      }
      then {
        an info diagnostic is emitted: authority role "admin" has no scenario coverage
      }
    }
  }

  coverage {

    unit {
      applies = true
    }

    integration {
      applies = true
    }
  }
}


contract "CON-2026-011" {
  title = "CLI Bootstrap"
  status = "complete"
  goal = "Mos has `mos init`, `mos rule create`, and `mos contract create` CLI commands, and the agent has used them to bootstrap Mos's own `.mos/` directory with zero lint errors."

  coverage {

    unit {
      applies = true
      rationale = "Init, CreateRule, CreateContract functions tested against temp dirs. Verify produced files parse and lint."
    }

    integration {
      applies = true
      rationale = "Full pipeline: cst init -> cst rule create -> cst lint on the same directory."
    }

    contract {
      applies = false
      rationale = "No external API."
    }

    e2e {
      applies = true
      rationale = "mos init . on Mos itself, followed by cst lint . with zero errors."
    }

    performance {
      applies = false
      rationale = "Not in scope"
    }

    concurrency {
      applies = false
      rationale = "CLI commands are sequential."
    }

    security {
      applies = false
      rationale = "Local file creation only. No network, no credentials."
    }
  }

  feature "Governance CLI" {

    scenario "mos init creates a valid scaffold" {
      given {
        an empty directory with no .cst/ directory
      }
      when {
        cst init . --model bdfl --scope cabinet --name test-project is run
      }
      then {
        .cst/config.cst exists and contains a config block with model = "bdfl"
        .cst/vocabulary/default.cst exists with an empty vocabulary block
        .cst/resolution/layers.cst exists with a project layer
        .cst/declaration.cst exists with name = "test-project"
        .cst/rules/ directory exists
        .cst/contracts/ directory exists
        cst lint . passes with zero diagnostics
      }
    }

    scenario "mos rule create produces a lintable rule" {
      given {
        a directory with a valid .cst/ scaffold
      }
      when {
        cst rule create go-build-pass --type mechanical --enforcement error --harness-cmd "go build ./..." is run
      }
      then {
        .cst/rules/go-build-pass.cst exists
        the file contains a rule block with type = "mechanical" and enforcement = "error"
        the file contains a harness block with command = "go build ./..."
        cst lint . passes with zero diagnostics
      }
    }

    scenario "mos contract create produces a lintable contract" {
      given {
        a directory with a valid .cst/ scaffold
      }
      when {
        cst contract create CON-2026-042 --title "Test Contract" --status draft --goal "Test goal" is run
      }
      then {
        .cst/contracts/draft/CON-2026-042/contract.cst exists
        the file contains a contract block with status = "draft" and goal = "Test goal"
        cst lint . passes with zero diagnostics
      }
    }

    scenario "Self-hosted bootstrap -- Mos governs itself" {
      given {
        the mos/ repository with no .cst/ directory
      }
      when {
        the agent runs cst init, cst rule create, and cst lint via the CLI
      }
      then {
        .cst/ directory exists with config, vocabulary, layers, declaration, and rules
        all artifacts were produced by CLI commands (no direct file writes)
        cst lint . passes with zero diagnostics
        go test ./... still passes
      }
    }
  }
}


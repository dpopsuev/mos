contract "CON-2026-164" {
  title = "Enforce consistent error wrapping in governance"
  status = "complete"
  created_at = 2026-03-04T18:44:23Z
  updated_at = 2026-03-04T18:44:23Z
  goal = "Every error return in governance/ must wrap with fmt.Errorf(\"operation: %%w\", err) providing call-site context. No bare return err in any exported function. Add a go vet or linter rule (or static check in CI) that flags bare error returns in governance/. Target: zero bare return err in governance/*.go exported functions."
  kind = "feature"

  acceptance {

    criterion "zero-bare-returns" {
      description = "Zero bare return err in exported functions across governance/*.go"
    }

    criterion "context-wrapping" {
      description = "Every error return uses fmt.Errorf with operation context and %%w verb"
    }

    criterion "build-clean" {
      description = "go build ./... and go test ./... pass with zero errors"
    }
  }
  sprint = "SPR-2026-011"
}


specification "SPEC-2026-024" {
  title = "Full Onboarding Wizard for mos init"
  status = "active"
  enforcement = "disabled"
  slug = "spec-init-wizard"
  description = "Extend mos init from basic scaffolding to a full interactive onboarding wizard. The wizard walks through: LLM provider selection, Gateway configuration for external systems, writing the project Declaration interactively, choosing a governance model (BDFL, committee, consensus, or custom), setting governance defaults (graduated ceremony levels), identity registration (SSH key detection), and optional parent constitution for organizational inheritance. The result is a .mos/ initialized with the project founding document, chosen rules of self-governance, and first identity. Manifesto Section 5."
  name = "Full Onboarding Wizard for mos init"

  feature "Governance model selection" {
  }

  feature "Interactive Declaration drafting" {
  }

  feature "Identity and parent registration" {
  }
  justifies = "NEED-2026-001"

  spec {
    include "cmd/mos"
  }
  state = "current"
  group = "cli"
}


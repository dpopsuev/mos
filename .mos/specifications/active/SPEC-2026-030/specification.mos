specification "SPEC-2026-030" {
  title = "Case Study: OpenAI Codex — Harness Engineering in an Agent-First World"
  status = "active"
  enforcement = "disabled"

  section "Source" {
    url = "https://openai.com/index/harness-engineering/"
    author = "Ryan Lopopolo, OpenAI"
    date = "2026-02-11"
  }

  section "Context" {
    text = "OpenAI built and shipped an internal product with zero manually-written code. Three engineers drove ~1,500 PRs over five months using Codex, averaging 3.5 PRs/engineer/day. The codebase reached ~1M lines. Humans steer, agents execute."
  }

  section "Key Findings" {
    text = "1. Repository knowledge as system of record: AGENTS.md is a table of contents (~100 lines), not an encyclopedia. Deep docs live in a structured docs/ directory with design docs, exec plans, product specs, and references. Progressive disclosure — agents start with a small stable entry point and are taught where to look next. 2. Mechanical enforcement: Custom linters and CI jobs validate that the knowledge base is up to date, cross-linked, and structured correctly. Architecture is enforced via structural tests with strict layer boundaries. Taste invariants (naming, logging, file size) are encoded as lint rules with remediation instructions injected into agent context. 3. Entropy management: A recurring 'garbage collection' process runs background Codex tasks that scan for deviations against 'golden principles', update quality grades, and open targeted refactoring PRs. Technical debt is paid down continuously in small increments. 4. Application legibility: The app is made bootable per git worktree so agents can launch isolated instances. Chrome DevTools Protocol, DOM snapshots, screenshots, and observability tooling (LogQL, PromQL) are wired into the agent runtime. 5. Minimal blocking merge gates: PRs are short-lived. Test flakes are addressed with follow-ups rather than blocking progress. Corrections are cheap; waiting is expensive."
  }

  section "Relevance to Mos" {
    text = "Strong validation of Mos's core thesis. OpenAI independently discovered that governance artifacts (rules, architecture docs, plans, quality grades) must be versioned, structured, mechanically validated, and co-located with code. Their docs/ structure mirrors Mos's .mos/ directory. Their custom linters mirror Mos's linter. Their 'golden principles' are analogous to Mos rules. Their exec plans are analogous to Mos contracts. Key difference: OpenAI built bespoke tooling; Mos aims to provide a reusable, domain-agnostic governance framework."
  }
  slug = "case-study-openai-codex"
  justifies = "NEED-2026-002"
  group = "research"
  state = "current"
}

